<Window x:Class="AnimeSubscriber.Dialogs.EpisodeSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AnimeSubscriber.Converters"
        Title="选择要下载的剧集" Width="680" Height="560"
        MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BgCardBrush}"
        FontFamily="{StaticResource BodyFont}"
        FontSize="{StaticResource NormalFontSize}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- List -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock x:Name="TitleLabel" Text="选择要下载的剧集"
                           FontSize="{StaticResource TitleFontSize}" FontWeight="Bold"/>
                <TextBlock x:Name="CountLabel" Text=""
                           FontSize="{StaticResource SmallFontSize}"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Episode List -->
        <ListBox x:Name="EpisodeList" Grid.Row="1"
                 BorderThickness="0" Background="Transparent"
                 SelectionMode="Extended"
                 Margin="8,4"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Height="36" Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- CheckBox -->
                        <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="8,0,8,0"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"/>

                        <!-- Episode number -->
                        <TextBlock Grid.Column="1" Text="{Binding Episode, StringFormat='第{0:D2}话'}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   FontWeight="SemiBold" MinWidth="52"/>

                        <!-- Title -->
                        <TextBlock Grid.Column="2" Text="{Binding Title}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="{StaticResource SmallFontSize}"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Badges -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,12,0">
                            <Border Background="{StaticResource BgSecondaryBrush}"
                                    CornerRadius="3" Padding="6,2" Margin="0,0,4,0"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding Subgroup}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"  VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#edf6f3"
                                    CornerRadius="3" Padding="6,2"
                                    BorderBrush="{StaticResource TealBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding Quality}" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TealBrush}" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Bottom buttons -->
        <Border Grid.Row="2" Padding="16,8"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="全选" Style="{StaticResource SecondaryButton}"
                            Width="72" Height="32" Click="SelectAll_Click"/>
                    <Button Content="取消全选" Style="{StaticResource SecondaryButton}"
                            Height="32" Margin="6,0,0,0" Click="DeselectAll_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ConfirmBtn" Content="确认下载 (0)" Style="{StaticResource CoralButton}"
                            Width="140" Height="32" Click="Confirm_Click"/>
                    <Button Content="取消" Style="{StaticResource SecondaryButton}"
                            Width="80" Height="32" Margin="6,0,0,0" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
