<Window x:Class="AnimeSubscriber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AnimeSubscriber.Views"
        xmlns:vm="clr-namespace:AnimeSubscriber.ViewModels"
        Title="AnimeSubscriber" Height="740" Width="1200"
        MinHeight="560" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        FontFamily="{StaticResource BodyFont}"
        FontSize="{StaticResource NormalFontSize}">

    <Window.Resources>

        <!-- ══ Page ↔ View mapping ══ -->
        <DataTemplate DataType="{x:Type vm:MainViewModel+SubscriptionsActive}">
            <views:SubscriptionsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MainViewModel+DownloadsActive}">
            <views:DownloadsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MainViewModel+SettingsActive}">
            <views:SettingsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MainViewModel+LogsActive}">
            <views:LogsPage/>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Top Header Bar ══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource SidebarBgBrush}"
                BorderBrush="{StaticResource SidebarDividerBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <TextBlock Text="🎬" FontSize="14" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="AnimeSubscriber" FontWeight="Bold" FontSize="14"
                           Foreground="{StaticResource OnDarkBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ══ Sidebar ══ -->
        <Border Grid.Row="1" Grid.Column="0"
                Background = "Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="48"/>
                </Grid.RowDefinitions>

                <!-- Nav buttons -->
                <StackPanel Margin="0,8,0,0">
                    <Button x:Name="BtnSubs"      Content="📺  订阅管理"
                            Command="{Binding NavCommand}" CommandParameter="subs"/>
                    <Button x:Name="BtnDownloads" Content="📥  下载状态"
                            Command="{Binding NavCommand}" CommandParameter="downloads"/>
                    <Button x:Name="BtnSettings"  Content="⚙  设置"
                            Command="{Binding NavCommand}" CommandParameter="settings"/>
                    <Button x:Name="BtnLogs"      Content="📋  日志"
                            Command="{Binding NavCommand}" CommandParameter="logs"/>
                </StackPanel>

                <!-- qBit connection status -->
                <Border Grid.Row="1"
                        BorderBrush="{StaticResource SidebarDividerBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,8">
                    <TextBlock x:Name="SidebarStatus" Text="● 未连接"
                               FontSize="{StaticResource SmallFontSize}"
                               Foreground="{StaticResource OnDarkSoftBrush}"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ Page Content ══ -->
        <ContentControl Grid.Row="1" Grid.Column="1"
                        Content="{Binding CurrentPage}"
                        Margin="0"/>

        <!-- ══ Status Bar ══ -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="StatusEntries" Text="共 0 个订阅"
                           FontSize="{StaticResource SmallFontSize}"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource SmallFontSize}"
                           Foreground="{StaticResource ErrorBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusNextCheck" Text="下次检查: --"
                           FontSize="{StaticResource SmallFontSize}"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,0"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
