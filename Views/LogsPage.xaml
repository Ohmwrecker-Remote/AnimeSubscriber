<UserControl x:Class="AnimeSubscriber.Views.LogsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrimaryBrush}">

    <Border Style="{StaticResource CardPanel}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,0,0,1" Padding="12,10" Margin="-12,0,-12,4">
                <Grid>
                    <TextBlock Text="📋 日志" FontSize="{StaticResource TitleFontSize}" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="🔄 刷新" Style="{StaticResource SuccessButton}"
                                Command="{Binding RefreshCommand}" Margin="0,0,6,0"/>
                        <Button Content="📂 打开日志" Style="{StaticResource CoralButton}"
                                Command="{Binding OpenFileCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Log text -->
            <TextBox Grid.Row="1" Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                     Background="{StaticResource BgCardBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderThickness="0" Margin="-8,4,-8,0"
                     TextWrapping="NoWrap"/>
        </Grid>
    </Border>
</UserControl>
