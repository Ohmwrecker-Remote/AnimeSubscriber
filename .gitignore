# Whitelist: ignore everything
*

# ── Un-ignore allowed content ──
!.gitignore

!/Config
!/Config/*
!/Converters
!/Converters/*
!/Dialogs
!/Dialogs/*
!/Models
!/Models/*
!/Services
!/Services/*
!/Themes
!/Themes/*
!/ViewModels
!/ViewModels/*
!/Views
!/Views/*

!/*.csproj
!/*.sln
!/*.resx
!/*.cs
!/*.xaml
!/*.md
!/appsettings.json
!/LICENSE
